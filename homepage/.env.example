# ──────────────────────────────────────────────────────────────────────────
# storypay.io homepage — environment variables
# ──────────────────────────────────────────────────────────────────────────

# Where this marketing site is reachable (used for SEO / OG / canonical)
NEXT_PUBLIC_APP_URL=https://storypay.io

# Where the dashboard app lives (Log In button target)
NEXT_PUBLIC_DASHBOARD_URL=https://app.storyvenue.com

# Supabase — shared StoryPay project (needed for the waitlist form + sitemap)
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Resend — transactional email notifications for new waitlist signups
RESEND_API_KEY=<resend-key>

# Optional: Google Search Console site verification
GOOGLE_SITE_VERIFICATION=
