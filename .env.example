# ─────────────────────────────────────────────────────────────────────────────
# StoryVenue / StoryPay — Environment Variables
# Copy to .env.local for local development. NEVER commit real secrets.
# All variables marked [REQUIRED] must be set in Railway before going live.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of this Next.js app (used in email links, unsubscribe URLs, PDF links). No trailing slash.
# [REQUIRED]
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project → Settings → API
# [REQUIRED]
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (Transaction Pooler — IPv4 compatible for Railway).
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Get from: Supabase dashboard → Project → Settings → Database → Connection pooler → Transaction
# Encode any @ in the password as %40
# [REQUIRED for AI Concierge and any direct DB operations]
DATABASE_URL=
# Fallback if DATABASE_URL is unset:
SUPABASE_DB_URL=

# ── LunarPay / StoryPay™ ─────────────────────────────────────────────────────
# Agency key — required for venue StoryPay™ merchant onboarding wizard.
# Get from: LunarPay dashboard → Agency → API Keys
# [REQUIRED for payment processing]
LUNARPAY_AGENCY_KEY=

# Platform merchant secret key — for StoryVenue SaaS billing (directory plan subscriptions).
# This is the sk_ key for the StoryVenue/StoryPay platform merchant account, NOT the agency key.
# [REQUIRED for SaaS subscription billing]
STORYPAY_PLATFORM_LUNARPAY_SECRET_KEY=

# Optional: numeric LunarPay merchant ID for the platform account (debugging/webhook routing).
STORYPAY_PLATFORM_LUNARPAY_MERCHANT_ID=

# Webhook signature secret — used to verify LunarPay webhook POST requests.
# MUST be set in production — leaving it empty rejects ALL webhook calls.
# Get from: LunarPay dashboard → Webhooks → signing secret
# [REQUIRED — without this, payment webhooks are rejected]
LUNARPAY_WEBHOOK_SECRET=

# ── Resend (Email) ────────────────────────────────────────────────────────────
# Resend API key — used for all transactional + marketing email delivery.
# Get from: resend.com → API Keys
# [REQUIRED — without this, all email sending silently fails]
RESEND_API_KEY=

# Inbound email domain — the subdomain you registered in Resend for inbound routing
# (e.g. inbound.yourdomain.com). Used to construct reply-to addresses for conversation threads.
# [REQUIRED for email reply routing into conversation threads]
CONVERSATIONS_INBOUND_DOMAIN=

# HMAC secret for verifying the signed token in inbound email reply-to addresses.
# Generate: openssl rand -hex 32
# [REQUIRED for email reply routing]
CONVERSATIONS_INBOUND_SECRET=

# Optional: additional token to reject unknown callers on the inbound email webhook.
# INBOUND_EMAIL_WEBHOOK_TOKEN=

# Resend webhook signing secret — for email.opened / email.clicked / email.bounced events.
# Get from: resend.com → Webhooks → your endpoint → Signing secret
RESEND_WEBHOOK_SECRET=

# ── Marketing / Cron ─────────────────────────────────────────────────────────
# Cron auth token — all /api/cron/* endpoints require:
#   Authorization: Bearer <this value>   OR   ?secret=<this value>
# Generate: openssl rand -hex 32
# [REQUIRED for all scheduled jobs]
MARKETING_CRON_SECRET=

# Alternative name accepted by the app (CRON_SECRET = MARKETING_CRON_SECRET alias):
# CRON_SECRET=

# Signed token secret for unsubscribe / resubscribe / manage-preferences links in marketing emails.
# Generate a DIFFERENT value than MARKETING_CRON_SECRET: openssl rand -hex 32
# [REQUIRED — without this, unsubscribe links are guessable]
MARKETING_EMAIL_TOKEN_SECRET=

# ── AI Concierge ─────────────────────────────────────────────────────────────
# DeepSeek API key — powers AI Concierge SMS generation and Ask AI chat.
# Get from: platform.deepseek.com → API Keys
# [REQUIRED for AI Concierge and Ask AI features]
DEEPSEEK_API_KEY=
# Optional: override the DeepSeek model (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

# ── GHL / GoHighLevel (Legacy SMS) ────────────────────────────────────────────
# GHL Agency API key — used to send A2P SMS via connected GHL sub-accounts.
# Get from: GHL → Agency → Settings → API Keys
# [REQUIRED for SMS sending to legacy clients]
GHL_AGENCY_API_KEY=
GHL_PRIVATE_KEY=

# GHL Marketplace App credentials (for the OAuth install flow).
# Get from: GHL → Agency → Apps & Marketplace → your app
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# ── Integrations ─────────────────────────────────────────────────────────────
# QuickBooks OAuth (for QuickBooks Online accounting integration)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_ENVIRONMENT=sandbox  # or 'production'

# FreshBooks OAuth
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=

# Calendly OAuth
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=

# Google Calendar OAuth (for two-way Google Calendar sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google / Analytics ────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
# Optional: server-side Google Analytics measurement ID for listing analytics
# GOOGLE_ANALYTICS_MEASUREMENT_ID=

# ── Auth / Session ────────────────────────────────────────────────────────────
# Secret for signing session cookies / JWT tokens.
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000  # override for production if needed

# ── Misc ──────────────────────────────────────────────────────────────────────
# Base URL for Railway (used in some admin scripts). Usually same as NEXT_PUBLIC_APP_URL.
# MARKETING_CRON_BASE_URL=https://your-service.up.railway.app

# Fortis / StoryPay platform merchant ID (directory SaaS checkout).
# STORYPAY_PLATFORM_FORTIS_MERCHANT_ID=
