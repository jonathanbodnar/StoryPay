# Copy to .env.local for local dev (never commit real secrets).

# Public URL of this Next.js app (emails: merge links, unsubscribe base). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Marketing email cron auth — GET /api/cron/marketing-email must send:
#   Authorization: Bearer <this value>   OR   ?secret=<this value>
# Generate: openssl rand -hex 32
MARKETING_CRON_SECRET=

# Alternative name (either MARKETING_CRON_SECRET or CRON_SECRET is read by the app)
# CRON_SECRET=

# Unsubscribe + signed marketing links. Required in production.
# Generate a different value than the cron secret: openssl rand -hex 32
MARKETING_EMAIL_TOKEN_SECRET=

# Optional: base URL for scripts/marketing-email-cron.sh when not using Railway’s domain
# MARKETING_CRON_BASE_URL=https://your-service.up.railway.app

# --- Typical StoryPay / Supabase (see README or Supabase dashboard) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=
